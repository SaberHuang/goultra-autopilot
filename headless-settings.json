{
  "_comment": "goultra-autopilot headless 剪輯 session 專用權限 profile（claude -p --settings 本檔）。2026-07-14 dry-run 校準：路徑規則須用 // 開頭；Bash 整體放行、靠 deny 擋危險操作；sandbox 保持開啟＋ntfy 網域與 03_FCPX 寫入放行——代價是 suno-cli（Playwright 驅動 Chrome）在 sandbox 下預期會失敗，BGM 走庫存曲 fallback。若 Saber 明確授權 sandbox 關閉（讓 suno 可用），把 sandbox.enabled 改 false。前提：trigger.sh 會在啟動 claude 前先拉起 PalmierPro（MCP 是啟動時連線）。",
  "permissions": {
    "defaultMode": "dontAsk",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Agent",
      "Skill",
      "PushNotification",
      "TodoWrite",
      "Monitor",
      "TaskOutput",
      "TaskStop",
      "ToolSearch",
      "Bash",
      "Write(//Users/saber/03_FCPX/**)",
      "Edit(//Users/saber/03_FCPX/**)",
      "Write(//private/tmp/**)",
      "Edit(//private/tmp/**)",
      "mcp__palmier-pro"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(sudo *)",
      "Bash(diskutil *)",
      "Bash(launchctl *)",
      "Bash(git push*)",
      "Write(//Users/saber/03_FCPX/Insta360_RAW/**/VID_*.mp4)",
      "Write(//Users/saber/03_FCPX/Insta360_RAW/**/IMG_*)",
      "Edit(//Users/saber/03_FCPX/Insta360_RAW/**/VID_*.mp4)",
      "Edit(//Users/saber/03_FCPX/Insta360_RAW/**/IMG_*)"
    ],
    "additionalDirectories": [
      "/Users/saber/03_FCPX",
      "/Users/saber/03_GitHub/suno-cli"
    ]
  },
  "sandbox": {
    "enabled": true,
    "network": {
      "allowedDomains": ["ntfy.sh"]
    },
    "filesystem": {
      "allowWrite": [
        "/Users/saber/03_FCPX",
        "/private/tmp"
      ]
    }
  },
  "enableAllProjectMcpServers": true,
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "inputNeededNotifEnabled": true
}
