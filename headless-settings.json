{
  "_comment": "goultra-autopilot headless 剪輯 session 專用權限 profile（claude -p --settings 本檔）。2026-07-14 定案：sandbox 已由 Saber 授權關閉（enabled:false）——因為 sandbox 會靜默弄壞 FunASR（footage_srt Phase 0 語音草稿 exit 0 但零輸出→整片脈絡崩）、suno-cli、curl 三樣，是 headless 首跑失控的根因。關 sandbox 後靠 deny 清單（rm/sudo/diskutil/launchct/git push/原始素材寫入）當安全底線。路徑規則須用 // 開頭。前提：trigger.sh 會在啟動 claude 前先拉起 PalmierPro（MCP 是啟動時連線）。",
  "permissions": {
    "defaultMode": "dontAsk",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Agent",
      "Skill",
      "PushNotification",
      "TodoWrite",
      "Monitor",
      "TaskOutput",
      "TaskStop",
      "ToolSearch",
      "Bash",
      "Write(//Users/saber/03_FCPX/**)",
      "Edit(//Users/saber/03_FCPX/**)",
      "Write(//private/tmp/**)",
      "Edit(//private/tmp/**)",
      "mcp__palmier-pro"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(sudo *)",
      "Bash(diskutil *)",
      "Bash(launchctl *)",
      "Bash(git push*)",
      "Write(//Users/saber/03_FCPX/Insta360_RAW/**/VID_*.mp4)",
      "Write(//Users/saber/03_FCPX/Insta360_RAW/**/IMG_*)",
      "Edit(//Users/saber/03_FCPX/Insta360_RAW/**/VID_*.mp4)",
      "Edit(//Users/saber/03_FCPX/Insta360_RAW/**/IMG_*)"
    ],
    "additionalDirectories": [
      "/Users/saber/03_FCPX",
      "/Users/saber/03_GitHub/suno-cli"
    ]
  },
  "sandbox": {
    "enabled": false
  },
  "enableAllProjectMcpServers": true,
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "inputNeededNotifEnabled": true
}
